{
    "name": "tigamadou/emecef-core-php",
    "description": "Framework-agnostic Core SDK for the Benin Republic e-MECeF (Electronic Tax Invoice) system",
    "type": "library",
    "license": "proprietary",
    "authors": [
        {
            "name": "Amadou IBRAHIM",
            "email": "contacts@magestive.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": ">=8.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "phpstan/phpstan": "^1.10",
        "squizlabs/php_codesniffer": "^3.10",
        "phpmd/phpmd": "^2.13"
    },
    "autoload": {
        "psr-4": {
            "Emecef\\Core\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Emecef\\Core\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "scripts": {
        "test": "phpunit",
        "phpstan": "phpstan analyse --no-progress",
        "phpcs": "phpcs || exit 1",
        "phpcbf": "phpcbf",
        "phpmd": "phpmd src text phpmd.xml || exit 1"
    },
    "minimum-stability": "stable"
}
